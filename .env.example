# ── Qdrant ──────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=ecen_docs

# ── Embeddings (OpenAI-compatible) ──────────────────
EMBEDDING_API_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small

# ── TAMU LLM API ────────────────────────────────────
OPENAI_API_KEY=your-tamu-api-key
OPENAI_MODEL=protected.gpt-5
OPENAI_BASE_URL=https://chat-api.tamu.ai/openai

# ── Crawler ─────────────────────────────────────────
TARGET_URL=https://engineering.tamu.edu/electrical/index.html
CRAWL_DELAY_SECONDS=1                         # be polite to the server
MAX_PAGES=500

# ── Re-index schedule ───────────────────────────────
REINDEX_CRON=0 2 * * *                        # 2 AM daily

# ── In-app issue reporting (UI "Report a problem" → GitHub issue) ──
# Token with `issues: write` on the repo (fine-grained PAT). Leave blank to
# disable the /report-issue endpoint. Keep this server-side only — never expose.
GH_ISSUE_TOKEN=
GH_REPO=Aa-Rho-Hi/ECEN-Chatbot
